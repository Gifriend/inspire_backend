// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// 1. ENUMS
// ==============================

enum Role {
  MAHASISWA
  DOSEN
  KOORPRODI // Tambahan Role Baru
}

enum Gender {
  LAKI_LAKI
  PEREMPUAN
}

enum Status {
  AKTIF
  CUTI
  NON_AKTIF
  LULUS
  DROP_OUT
}

enum StatusMataKuliah {
  AKTIF
  NON_AKTIF
}

enum StatusKRS {
  DRAFT
  DIAJUKAN
  DISETUJUI
  DITOLAK
}

enum StatusNilai {
  BELUM_ADA
  SUDAH_ADA
}

enum SessionType {
  KELAS
  UAS
  EVENT
}

// ==============================
// 2. DATA MASTER (Fakultas, Prodi, User)
// ==============================

model Fakultas {
  id    Int     @id @default(autoincrement())
  name  String
  kode  String  @unique
  dekan String?

  prodi Prodi[]
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Prodi {
  id         Int     @id @default(autoincrement())
  name       String
  kode       String  @unique
  jenjang    String // S1, S2, S3, D3, D4
  kaprodi    String?
  fakultasId Int

  fakultas   Fakultas     @relation(fields: [fakultasId], references: [id], onDelete: Cascade)
  users      User[]
  mataKuliah Matakuliah[]
  kurikulum  Kurikulum[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  nim          String?   @unique // Nullable untuk dosen/admin
  nip          String?   @unique // Untuk dosen/staff
  email        String    @unique
  fcmToken     String?
  role         Role
  gender       Gender
  password     String
  photo        String?
  status       Status
  alamat       String?
  telepon      String?
  tanggalLahir DateTime?
  fakultasId   Int
  prodiId      Int?

  fakultas Fakultas @relation(fields: [fakultasId], references: [id])
  prodi    Prodi?   @relation(fields: [prodiId], references: [id])

  // Relasi Mahasiswa
  krs             KRS[]
  nilai           Nilai[]
  skripsi         Skripsi[]
  submissions     Submission[] // E-Learning
  quizAttempts    QuizAttempt[] // E-Learning
  presensiRecords PresensiRecord[] // Presensi (Log Kehadiran)

  // Relasi Dosen
  mengajarMataKuliah  KelasPerkuliahan[]
  pembimbingSkripsi   Skripsi[]          @relation("PembimbingUtama")
  coPembimbingSkripsi Skripsi[]          @relation("CoPembimbing")
  pengumuman          Pengumuman[] // Pengumuman yang dibuat dosen/koorprodi

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==============================
// 3. AKADEMIK (Kurikulum, MK, Kelas)
// ==============================

model Kurikulum {
  id      Int              @id @default(autoincrement())
  name    String
  tahun   Int
  status  StatusMataKuliah @default(AKTIF)
  prodiId Int

  prodi      Prodi        @relation(fields: [prodiId], references: [id])
  mataKuliah Matakuliah[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Matakuliah {
  id          Int              @id @default(autoincrement())
  name        String
  kode        String           @unique
  sks         Int
  semester    Int // 1-14
  jenisMK     String // Wajib, Pilihan
  deskripsi   String?
  silabus     String?
  status      StatusMataKuliah @default(AKTIF)
  prodiId     Int
  kurikulumId Int

  prodi            Prodi              @relation(fields: [prodiId], references: [id])
  kurikulum        Kurikulum          @relation(fields: [kurikulumId], references: [id])
  prasyarat        PrasyaratMK[]      @relation("MataKuliahUtama")
  syaratUntuk      PrasyaratMK[]      @relation("MataKuliahPrasyarat")
  kelasPerkuliahan KelasPerkuliahan[]
  nilai            Nilai[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrasyaratMK {
  id                    Int @id @default(autoincrement())
  mataKuliahId          Int
  mataKuliahPrasyaratId Int

  mataKuliah          Matakuliah @relation("MataKuliahUtama", fields: [mataKuliahId], references: [id], onDelete: Cascade)
  mataKuliahPrasyarat Matakuliah @relation("MataKuliahPrasyarat", fields: [mataKuliahPrasyaratId], references: [id], onDelete: Cascade)

  @@unique([mataKuliahId, mataKuliahPrasyaratId])
}

model KelasPerkuliahan {
  id           Int     @id @default(autoincrement())
  kode         String  @unique
  nama         String
  kapasitas    Int
  ruangan      String?
  jadwal       String? // JSON string
  academicYear String // "2024/2025 Ganjil"
  mataKuliahId Int
  dosenId      Int

  mataKuliah Matakuliah @relation(fields: [mataKuliahId], references: [id])
  dosen      User       @relation(fields: [dosenId], references: [id])
  krs        KRS[]

  // E-Learning Sessions (Materi & Tugas)
  sessions Session[]

  // Presensi Sessions (Absensi Kehadiran)
  presensiSessions PresensiSession[]

  // Pengumuman (Many-to-Many)
  pengumuman Pengumuman[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KRS {
  id                 Int       @id @default(autoincrement())
  academicYear       String // "2024/2025 Ganjil"
  status             StatusKRS @default(DRAFT)
  totalSKS           Int       @default(0)
  tanggalPengajuan   DateTime?
  tanggalPersetujuan DateTime?
  catatanDosen       String?
  mahasiswaId        Int
  kelasPerkuliahanId Int? // Ditambahkan agar relasi jelas di DB level (opsional jika pakai implicit many-to-many, tapi explicit lebih aman untuk report)

  mahasiswa User @relation(fields: [mahasiswaId], references: [id])

  // Perbaikan: Biasanya KRS Many-to-Many dengan Kelas, atau One-to-Many detail. 
  // Di schema Anda sebelumnya: KelasPerkuliahan[], yang berarti implicit many-to-many. 
  // Kita pertahankan implicit many-to-many agar konsisten dengan schema lama Anda.
  kelasPerkuliahan KelasPerkuliahan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // @@unique([mahasiswaId, semester]) // PERHATIAN: Unique ini menyebabkan error jika mahasiswa ambil banyak kelas di semester sama.
  // Sebaiknya unique hanya jika struktur KRS adalah Header. Jika KRS adalah Detail (per matkul), hapus unique ini.
  // Asumsi: Model ini adalah Header KRS (Satu per semester per mahasiswa).
  @@unique([mahasiswaId, academicYear])
}

model Nilai {
  id           Int         @id @default(autoincrement())
  nilaiTugas   Float?      @default(0)
  nilaiUTS     Float?      @default(0)
  nilaiUAS     Float?      @default(0)
  nilaiAkhir   Float?      @default(0)
  nilaiHuruf   String? // A, B+, B, C+, C, D, E
  indeksNilai  Float? // 4.0, 3.5, 3.0
  status       StatusNilai @default(BELUM_ADA)
  academicYear String // "2024/2025 Ganjil"
  mahasiswaId  Int
  mataKuliahId Int

  mahasiswa  User       @relation(fields: [mahasiswaId], references: [id])
  mataKuliah Matakuliah @relation(fields: [mataKuliahId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mahasiswaId, mataKuliahId, academicYear])
}

// ==============================
// 4. FITUR BARU: PRESENSI (KEHADIRAN)
// ==============================

model PresensiSession {
  id     Int         @id @default(autoincrement())
  title  String
  type   SessionType @default(KELAS)
  date   DateTime    @default(now())
  isOpen Boolean     @default(true)

  // NEW: Token unik 8 karakter untuk absen
  token String @unique

  kelasPerkuliahanId Int?
  kelasPerkuliahan   KelasPerkuliahan? @relation(fields: [kelasPerkuliahanId], references: [id])

  records PresensiRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Model Data Absen Mahasiswa
model PresensiRecord {
  id Int @id @default(autoincrement())

  // HAPUS: swafotoUrl
  // GANTI: method (Untuk tahu dia absen pakai TOKEN atau MANUAL oleh dosen)
  method String @default("TOKEN") // "TOKEN" atau "MANUAL"

  createdAt DateTime @default(now())

  sessionId Int
  session   PresensiSession @relation(fields: [sessionId], references: [id])

  mahasiswaId Int
  mahasiswa   User @relation(fields: [mahasiswaId], references: [id])

  @@unique([sessionId, mahasiswaId])
}

// ==============================
// 5. FITUR UPDATE: PENGUMUMAN (MULTI-KELAS)
// ==============================

model Pengumuman {
  id        Int     @id @default(autoincrement())
  judul     String
  isi       String
  kategori  String // AKADEMIK, KEMAHASISWAAN, UMUM
  prioritas String  @default("NORMAL")
  aktif     Boolean @default(true)

  dosenId Int
  dosen   User @relation(fields: [dosenId], references: [id])

  // UPDATE: Relasi Many-to-Many ke KelasPerkuliahan
  // (Satu pengumuman bisa masuk ke banyak kelas, satu kelas bisa punya banyak pengumuman)
  kelas KelasPerkuliahan[]

  // Penanda jika pengumuman ini Global (misal dari Koorprodi untuk semua, tanpa terikat kelas)
  isGlobal Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==============================
// 6. SKRIPSI
// ==============================

model Skripsi {
  id                Int       @id @default(autoincrement())
  judul             String
  abstrak           String?
  statusPengajuan   String    @default("DRAFT")
  tanggalPengajuan  DateTime?
  tanggalSidang     DateTime?
  nilaiAkhir        Float?
  mahasiswaId       Int       @unique
  pembimbingUtamaId Int
  coPembimbingId    Int?

  mahasiswa       User  @relation(fields: [mahasiswaId], references: [id])
  pembimbingUtama User  @relation("PembimbingUtama", fields: [pembimbingUtamaId], references: [id])
  coPembimbing    User? @relation("CoPembimbing", fields: [coPembimbingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==============================
// 7. E-LEARNING (Materi, Tugas, Kuis)
// ==============================

model Session {
  id                 String  @id @default(uuid())
  title              String
  description        String?
  weekNumber         Int
  kelasPerkuliahanId Int

  kelasPerkuliahan KelasPerkuliahan @relation(fields: [kelasPerkuliahanId], references: [id])

  materials   Material[]
  assignments Assignment[]
  quizzes     Quiz[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Material {
  id        String       @id @default(uuid())
  title     String
  type      MaterialType
  content   String?
  fileUrl   String?
  sessionId String

  session Session @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

enum MaterialType {
  TEXT
  FILE
  HYBRID
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String?
  deadline    DateTime
  allowLate   Boolean  @default(false)
  sessionId   String

  session     Session      @relation(fields: [sessionId], references: [id])
  submissions Submission[]

  createdAt DateTime @default(now())
}

model Submission {
  id           String   @id @default(uuid())
  studentId    Int
  assignmentId String
  fileUrl      String?
  textContent  String?
  grade        Float?
  feedback     String?
  submittedAt  DateTime @default(now())

  student    User       @relation(fields: [studentId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id])
}

model Quiz {
  id            String            @id @default(uuid())
  title         String
  description   String?
  duration      Int
  startTime     DateTime
  endTime       DateTime
  gradingMethod QuizGradingMethod @default(HIGHEST_GRADE)
  sessionId     String

  session   Session       @relation(fields: [sessionId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]

  createdAt DateTime @default(now())
}

enum QuizGradingMethod {
  HIGHEST_GRADE
  LATEST_GRADE
  AVERAGE_GRADE
}

model Question {
  id            String       @id @default(uuid())
  text          String
  type          QuestionType
  options       Json?
  correctAnswer String?
  points        Int          @default(10)
  quizId        String

  quiz Quiz @relation(fields: [quizId], references: [id])
}

enum QuestionType {
  MULTIPLE_CHOICE
  ESSAY
  TRUE_FALSE
}

model QuizAttempt {
  id         String    @id @default(uuid())
  studentId  Int
  quizId     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  score      Float?

  student User @relation(fields: [studentId], references: [id])
  quiz    Quiz @relation(fields: [quizId], references: [id])
}
